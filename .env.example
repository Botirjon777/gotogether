# Copy to .env.local and fill in. Never commit real secrets.

# Canonical site origin (used for SEO metadata, sitemap, OG URLs)
NEXT_PUBLIC_SITE_URL=https://gotogether.uz

# Telegram contact-form integration (server-only)
# Create a bot with @BotFather, then add it to your group and read the chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
